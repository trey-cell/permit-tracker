# ─── Google Sheets ─────────────────────────────────────────────────────────────
# The ID from your Google Sheet URL
# Example: https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# Paste the entire contents of your service account JSON key here (one line, base64 encoded)
# Run: base64 -i your-service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_B64=your_base64_encoded_json_here

# ─── Notifications ─────────────────────────────────────────────────────────────
# Email address to send alerts to
NOTIFY_EMAIL=trey@relianthomebuyer.com

# SMTP settings (use Gmail app password or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
